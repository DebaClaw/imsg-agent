# Copy this to .env and fill in values. Never commit .env.

# OpenAI API key (required for drafting in Phase 2+)
OPENAI_API_KEY=sk-...

# Draft model (optional; defaults to config/imsg.json)
# IMSG_DRAFT_MODEL=gpt-5.5

# Override config file path (optional)
# IMSG_AGENT_CONFIG=~/src/imsg-agent/config/imsg.json

# Override data directory (optional)
# IMSG_DATA_DIR=~/imsg-data

# Set to 1 to enable integration tests against live imsg binary
# IMSG_INTEGRATION=0

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
